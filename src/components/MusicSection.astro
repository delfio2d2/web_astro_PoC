---
// src/components/MusicSection.astro

// Enfoque Data-Ready: Singles extraídos del WordPress original
const albumTitle = "MATTER.ANTIMATTER";
const releaseDate = "OUT ON 15TH JUNE";

const tracks = [
  { text: "PORTALS", href: "#" },
  { text: "SIRENS", href: "#" },
  { text: "SEASONS", href: "#" },
  { text: "THEOREMS OF AN UNEXPECTED HORIZON", href: "#" }
];
---

<section id="music" class="bg-base-100 py-20 px-4 md:px-8 border-b border-white/5">
  <div class="max-w-5xl mx-auto">
    
    <h2 class="text-3xl md:text-5xl font-black text-white uppercase tracking-wider mb-16 text-center">
      Music
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      
      <div class="flex justify-center group">
        <div class="w-full max-w-[450px] aspect-square border border-white/10 shadow-2xl overflow-hidden relative group-hover:border-primary/30 transition-colors duration-500">
          <img 
            src="/MATTER.ANTIMATTER_web.jpg" 
            alt={`Portada de ${albumTitle}`} 
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
          />
          <div class="absolute inset-0 bg-primary/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
        </div>
      </div>

      <div class="flex flex-col text-center md:text-left">
        
        <h3 class="text-2xl md:text-4xl font-black text-white uppercase tracking-wide mb-2">
          {albumTitle}
        </h3>
        
        <p class="text-lg font-bold tracking-widest text-[#918179] uppercase mb-8">
          {releaseDate}
        </p>

        <div class="w-12 h-[2px] bg-white/10 my-4 mx-auto md:mx-0"></div>

        <p class="text-xs font-bold tracking-[0.3em] text-white/40 uppercase mb-6 mt-4">
          MORE MUSIC ON STREAMING
        </p>

        <div class="flex flex-col gap-4 w-full max-w-md mx-auto md:mx-0">
          {tracks.map(track => (
            <a 
              href={track.href}
              class="btn btn-outline border-white/20 text-white rounded-none w-full text-left justify-between px-6 uppercase font-bold tracking-widest text-xs hover:bg-white hover:text-black hover:border-white transition-all duration-300"
            >
              <span>{track.text}</span>
              <span class="text-[10px] text-white/40 group-hover:text-black/40">➔</span>
            </a>
          ))}
        </div>

      </div>

    </div>

  </div>
</section>