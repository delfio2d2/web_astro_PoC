---
// src/components/TourSection.astro

// Enfoque Data-Ready: Mapeo de conciertos extraídos de la base de datos original
const pastShows = [
  {
    date: "SAT, MAR 7",
    venue: "LA LLORONA",
    city: "PLAZA V CENTENARIO, LA OROTAVA",
    status: "SHOW FINISHED"
  },
  {
    date: "SAT, JAN 24",
    venue: "LA LLORONA",
    city: "CALLE HURON, 10, LA LAGUNA",
    status: "SHOW FINISHED"
  },
  {
    date: "SAT, JUL 19, 2025",
    venue: "AGUERE CULTURAL",
    city: "CALLE HERRADORES, 47, LA LAGUNA",
    status: "SHOW FINISHED"
  },
  {
    date: "SAT, MAY 4, 2025",
    venue: "AGUERE CULTURAL",
    city: "CALLE HERRADORES, 47, LA LAGUNA",
    status: "SHOW FINISHED"
  }
];
---

<section id="tour" class="bg-[#141313] py-20 px-4 md:px-8 border-b border-white/5">
  <div class="max-w-5xl mx-auto">
    
    <!-- Título Principal de la Sección -->
    <h2 class="text-3xl md:text-5xl font-black text-white uppercase tracking-wider mb-16 text-center">
      Tour Dates
    </h2>

    <!-- BLOQUE 1: PRÓXIMOS CONCIERTOS -->
    <div class="mb-20 text-center">
      <h3 class="text-xs font-bold tracking-[0.4em] text-primary uppercase mb-6">
        Upcoming Shows
      </h3>
      <div class="border border-white/5 bg-black/40 p-8 max-w-xl mx-auto backdrop-blur-sm">
        <p class="text-sm text-white/50 tracking-widest uppercase font-light">
          MORE SHOWS COMING SOON
        </p>
      </div>
    </div>

    <!-- BLOQUE 2: CONCIERTOS PASADOS -->
    <div class="w-full">
      <h3 class="text-xs font-bold tracking-[0.4em] text-white/40 uppercase mb-8 text-center md:text-left">
        Past Shows
      </h3>

      <!-- Tabla / Lista de Filas de Conciertos -->
      <div class="flex flex-col border-t border-white/5">
        {pastShows.map(show => (
          <div class="flex flex-col md:flex-row items-center justify-between py-6 border-b border-white/5 gap-4 text-center md:text-left hover:bg-white/[0.01] transition-colors px-2 md:px-4">
            
            <!-- Columna 1: Fecha (Color bronce de la identidad de la banda) -->
            <div class="md:w-1/4">
              <span class="text-sm font-black tracking-wider text-[#918179] uppercase">
                {show.date}
              </span>
            </div>

            <!-- Columna 2: Recinto / Lugar -->
            <div class="md:w-1/4">
              <span class="text-sm font-bold text-white uppercase tracking-wide">
                {show.venue}
              </span>
            </div>

            <!-- Columna 3: Ciudad / Dirección -->
            <div class="md:w-1/3">
              <span class="text-xs text-white/50 uppercase tracking-widest font-light block">
                {show.city}
              </span>
            </div>

            <!-- Columna 4: Estado del Botón (Estética industrial recta y deshabilitada) -->
            <div class="md:w-1/6 flex justify-end w-full md:w-auto">
              <button 
                disabled
                class="btn btn-sm btn-outline text-white/30 border-white/10 rounded-none cursor-not-allowed uppercase font-bold tracking-widest text-[10px] w-full md:w-auto"
              >
                {show.status}
              </button>
            </div>

          </div>
        ))}
      </div>
    </div>

  </div>
</section>