---
// src/pages/privacy.astro
import Layout from '../layouts/Layout.astro'; // Ojo: sube solo un nivel (..) porque está directo en pages

interface LegalSection {
  number: string;
  titleEs: string;
  titleEn: string;
  contentEs: string;
  contentEn: string;
  itemsEs?: string[];
  itemsEn?: string[];
}

const legalSections: LegalSection[] = [
  {
    number: "1",
    titleEs: "Información que recopilamos",
    titleEn: "Information We Collect",
    contentEs: "Cuando visita nuestro Sitio, podemos recopilar y procesar los siguientes datos personales:",
    contentEn: "When you visit our Site, we may collect and process the following personal data:",
    itemsEs: [
      "Información de contacto: como nombre, dirección de correo electrónico, número de teléfono (si decide proporcionarnos esta información al suscribirse a nuestra newsletter o contactarnos).",
      "Datos de uso: información sobre su interacción con nuestro Sitio, como su dirección IP, tipo de navegador, páginas que visita y la duración de su visita.",
      "Datos de redes sociales: si interactúa con nosotros a través de redes sociales (por ejemplo, al seguirnos o hacer comentarios), podemos recopilar información pública de su perfil de esas plataformas."
    ],
    itemsEn: [
      "Contact information: such as name, email address, phone number (if you choose to provide this information by subscribing to our newsletter or contacting us).",
      "Usage data: information about your interaction with our Site, such as your IP address, browser type, pages visited, and the duration of your visit.",
      "Social media data: if you interact with us through social media (e.g., by following us or commenting), we may collect public profile information from those platforms."
    ]
  },
  // ... (el resto de las 10 secciones se mapean igual aquí dentro)
];
---

<Layout title="PRIVACY | FEARS OF RIPLEY">
  <main class="bg-[#141313] text-[#aaa9a9] min-h-screen py-16 px-4 md:px-8 font-sans">
    <div class="max-w-4xl mx-auto">
      
      <!-- Encabezado de la página -->
      <header class="text-center mb-16 border-b border-zinc-800 pb-8">
        <h1 class="text-3xl md:text-4xl font-bold tracking-wider text-white mb-2 font-display">POLÍTICA DE PRIVACIDAD</h1>
        <p class="text-xl font-medium text-zinc-500 tracking-widest uppercase">Privacy Policy</p>
      </header>

      <!-- Introducción Bilingüe -->
      <section class="mb-12 bg-zinc-900/30 p-6 rounded-lg border border-zinc-800/50">
        <p class="mb-4 text-white font-medium">
          FEARS OF RIPLEY (en adelante, "FOR") estamos comprometidos a proteger y respetar su privacidad. Esta política de privacidad explica cómo recopilamos, utilizamos y protegemos la información personal que nos proporciona cuando visita nuestro sitio web <span class="text-zinc-300">www.fearsofripley.com</span> (en adelante, “el Sitio”).
        </p>
        <hr class="border-zinc-800 my-4" />
        <p class="text-zinc-400 italic">
          FEARS OF RIPLEY (hereinafter, "FOR") is committed to protecting and respecting your privacy. This privacy policy explains how we collect, use, and protect the personal information you provide when visiting our website <span class="text-zinc-300">www.fearsofripley.com</span> (hereinafter, “the Site”).
        </p>
      </section>

      <!-- Renderizado Dinámico de las Secciones Legales (Data-Ready) -->
      <div class="space-y-12">
        {legalSections.map((section) => (
          <article class="border-l-2 border-zinc-700 pl-6 space-y-6">
            
            <!-- Bloque Castellano -->
            <div class="space-y-2">
              <h2 class="text-lg font-bold text-white tracking-wide uppercase">
                {section.number}. {section.titleEs}
              </h2>
              <p class="leading-relaxed text-zinc-300">{section.contentEs}</p>
              {section.itemsEs && (
                <ul class="list-disc list-inside pl-2 space-y-1 text-zinc-400 text-sm">
                  {section.itemsEs.map((item) => <li>{item}</li>)}
                </ul>
              )}
            </div>

            <!-- Bloque Inglés -->
            <div class="space-y-2 bg-zinc-900/10 p-3 rounded border border-zinc-800/20">
              <h3 class="text-sm font-bold text-zinc-400 tracking-wide uppercase">
                {section.number}. {section.titleEn}
              </h3>
              <p class="leading-relaxed text-zinc-500 text-sm">{section.contentEn}</p>
              {section.itemsEn && (
                <ul class="list-disc list-inside pl-2 space-y-1 text-zinc-600 text-xs">
                  {section.itemsEn.map((item) => <li>{item}</li>)}
                </ul>
              )}
            </div>

          </article>
        ))}
      </div>

      <!-- Footer Unificado de Contacto Directo -->
      <footer class="mt-16 pt-8 border-t border-zinc-800 text-center">
        <p class="text-zinc-400 text-sm">
          Canal oficial de contacto de privacidad / Official privacy contact: 
          <a href="mailto:contact@fearsofripley.com" class="text-white hover:underline transition-all block sm:inline font-semibold mt-1 sm:mt-0 ml-0 sm:ml-1">
            contact@fearsofripley.com
          </a>
        </p>
      </footer>

    </div>
  </main>
</Layout>